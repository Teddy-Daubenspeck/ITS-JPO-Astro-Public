---
import ProgramSection from "@/src/components/programs/ProgramSection.astro";
import Layout from "./_layout.astro";
import Card from "@/src/components/programs/card/Card.astro";
import CardHeader from "@/src/components/programs/card/CardHeader.astro";
import CardBody from "@/src/components/programs/card/CardBody.astro";
import Link from "@/src/components/Link.astro";
import intersectionCrashesImage from "@/src/assets/images/strategic-technology-for-roadway-safety/intersection-crashes.png";
import userDeathsImage from "@/src/assets/images/strategic-technology-for-roadway-safety/user-deaths.png";
import { Image } from "astro:assets";
import CardFooter from "@/src/components/programs/card/CardFooter.astro";
import iscLogo from "@/src/assets/images/strategic-technology-for-roadway-safety/isc-logo.png";
import issLogo from "@/src/assets/images/strategic-technology-for-roadway-safety/iss-logo.png";
import base_url from "@/src/lib/base_url";
import plusIcon from "@/src/assets/images/strategic-technology-for-roadway-safety/plus.png";
import equalsIcon from "@/src/assets/images/strategic-technology-for-roadway-safety/equals.png";
import dataFusionIcon from "@/src/assets/images/strategic-technology-for-roadway-safety/data-fusion.png";
import aiIcon from "@/src/assets/images/strategic-technology-for-roadway-safety/ai.png";
import integrationIcon from "@/src/assets/images/strategic-technology-for-roadway-safety/integration.png";
import safeIntersectionImage from "@/src/assets/images/strategic-technology-for-roadway-safety/safe-intersection.jpg";
import BoxArrowUpRightIcon from "@/src/components/programs/icons/BoxArrowUpRightIcon.astro";
import PdfIcon from "@/src/components/programs/icons/PdfIcon.astro";
import wideProgramLogo from "@/src/assets/images/strategic-technology-for-roadway-safety/wide-program-logo.jpg";

---
<style>
  .overview-section {
    display: flex;
    flex-direction: column;
    gap: var(--size-lg);
  }
  .overview-image {
    border-radius: var(--border-radius);
  }

  @media (min-width: 992px) {
    .overview-section {
      flex-direction: row;
      align-items: center;
    }
    .overview-image {
      flex-basis: 40%;
    }
    .overview-text {
      flex-basis: 60%;
    }
  }
</style>
<style>
  .vision-container {
    background: rgb(var(--color-gray-light));
    border-radius: var(--radius-md);
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
</style>
<style>
  .problem-container {
    display: grid;
    grid-template-columns: repeat(1, 1fr);
    gap: var(--size);
  }

  .problem {
    display: flex;
    flex-direction: column;
    gap: var(--size);
    padding: var(--size-xs);
    align-items: center;
  }

  .problem-image {
    max-width: 200px;
  }

  @media (min-width: 1200px) {
    .problem-container {
      grid-template-columns: repeat(2, 1fr);
    }

    .problem {
      flex-direction: row;
      align-items: center;
    }

    .problem-content {
      flex-basis: 70%;
    }

    .problem-image {
      flex-basis: 30%;
      padding: 0.5rem;
      height: auto;
    }
  }
</style>
<style>
  .stage-container {
    display: grid;
    grid-template-columns: repeat(1, 1fr);
    /* gap: var(--size); */
  }

  .stage-image {
    padding: var(--size)
  }

  @media (min-width: 1200px) {
    .stage-container {
      grid-template-columns: repeat(2, 1fr);
    }

    .stage {
      display: flex;
      flex-direction: column;
    }

    .stage-image {
      height: 200px;
      width: auto;
    }

    .stage-content {

    }
    .stage-left {
      padding-right: var(--size);
      border-right: 1px solid var(--border-light);
    }

    .stage-right {
      padding-left: var(--size);
    }
  }
</style>
<style>
  .resource-container {
    display: grid;
    grid-template-columns: repeat(1, 1fr);
    gap: var(--size);
  }

  .resource-card-header {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }
  .resource-card-title {
    text-transform: none;
  }
  .resource-card-subtitle {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
  }
  .resource-button {
    border: 1px solid #dee2e6;
    padding: 0.2rem 0.5rem;
    display: inline-block;
    text-align: center;
    text-decoration: none;
    gap: 1rem;
    justify-content: center;
    align-items: center;
    font-size: 0.9rem;
    font-weight: 600;
    color: black;
    border-radius: var(--radius-sm);
    transition: all var(--transition-duration) ease-in-out;
  }
  .resource-button::after {
    content: "";
  }
  .resource-button:hover {
    font-weight: 600;
    background: #dee2e6;
  }

  .resource-link-container {
    display: inline-flex;
    flex-direction: row;
    flex-wrap: wrap;
    gap: 4px;
  }

  @media (min-width: 1200px) {
    .resource-container {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
<style>
  .solution-container {
    display: flex;
    flex-direction: column;
    gap: var(--size);
    align-items: center;
  }

  .solution-symbol {
    width: 50px;
  }

  .solution-icon {
    max-width: 200px;
  }

  .solution-header {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .solution-card {
    padding: var(--size);
  }

  @media (min-width: 1200px) {
    .solution-container {
      display: grid;
      grid-template-columns: 1fr 0.1fr 1fr 0.1fr 1fr;
      grid-auto-rows: 1fr;
      gap: var(--size);
    }

    .solution-symbol {
      display: flex;
      align-items: center;
      justify-content: center;
      
    }

    .solution-card {
      height: 100%;
    }
  }
</style>
<Layout>
  <main class="program-main">
    <ProgramSection>
      <div class="overview-section">
        <div class="overview-text">
          <h2 class="program-title-lg">
            Program Overview
          </h2>
          <p class="program-text">
            Roadway crashes remain a serious safety challenge in the United States, resulting in 39,254 fatalities 
            in 2024 alone, including 7,080 pedestrian deaths. Reducing roadway fatalities continues to be a top priority 
            of the USDOT. Traditional infrastructure treatments (e.g., road diets, bicycle lane additions, intersection 
            redesigns, lighting improvements, and rumble strips) have demonstrated strong safety benefits; however, these 
            approaches are typically static, location-specific, and limited in their ability to address dynamic and/or 
            system-wide crash risks. 
          </p>
        </div>
        <div class="overview-image">
          <Image src={wideProgramLogo} alt="Wide Program Logo" class="img-fluid radius-md" />
        </div>
      </div>
      <div>
        <p>Intelligent Transportation Systems (ITS) offer a complementary and scalable solution by integrating sensing, 
          communications, data analytics, automation, and vehicle-to-everything (V2X) technologies to proactively monitor, 
          manage, and mitigate evolving safety risks across the transportation network. For example, pedestrian fatalities 
          can be reduced through the deployment of different ITS technologies, including automated pedestrian detection systems, 
          connected vehicle-to-infrastructure (V2I) pedestrian warning applications, active warning devices such as Rectangular 
          Rapid Flashing Beacons (RRFBs), and adaptive traffic signal control that extends pedestrian crossing times. 
          These technologies can both complement traditional infrastructure interventions or be used as standalone solutions.</p>
      </div>
      <div class="overview-text">
          <h2 class="program-title-lg">
            Program Vision
          </h2>
          <p class="program-text">
            Create safer communities by minimizing roadway fatalities and serious injuries through research and 
            deployment of transformative ITS technologies. The program promotes research, testing, and large-scale 
            deployment of advanced ITS solutions [JC20.1][RG20.2]while fostering outreach, education and stakeholder 
            engagement to accelerate widespread adoption and address today’s safety challenges while preparing for 
            future transportation needs. 
          </p>
        </div>
        <div class="overview-text">
          <h2 class="program-title-lg">
            Program Mission
          </h2>
          <p class="program-text">
            Advance roadway safety through purpose-driven innovation by championing strategic 
            initiatives, incubating transformative safety technologies, and educating decision 
            makers about proven life-saving ITS solutions to support large scale deployment. 
            These efforts support safer mobility, protect all road users, and contribute to more 
            resilient and efficient transportation networks.
          </p>
        </div>
  </main>
</Layout>